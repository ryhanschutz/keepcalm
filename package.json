{
  "name": "keepcalm-secure",
  "version": "1.1.1",
  "description": "KeepCalm E2EE P2P Desktop Client",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ryhanschutz/keepcalm.git"
  },
  "build": {
    "appId": "com.ryhanschutz.keepcalm",
    "productName": "KeepCalm",
    "directories": {
      "output": "dist_build"
    },
    "win": {
      "target": "nsis",
      "icon": "favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "KeepCalm",
      "installerIcon": "favicon.ico",
      "uninstallerIcon": "favicon.ico"
    }
  },
  "author": "Ryhan Schutz",
  "license": "MIT",
  "devDependencies": {
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2"
  }
}
