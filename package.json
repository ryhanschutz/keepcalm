{
  "name": "keepcalm-secure",
  "version": "1.1.9",
  "description": "KeepCalm E2EE P2P Desktop Client",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ryhanschutz/keepcalm-yole.git"
  },
  "build": {
    "appId": "com.ryhanschutz.keepcalm",
    "productName": "KeepCalm",
    "directories": {
      "output": "dist_build"
    },
    "win": {
      "target": "portable",
      "icon": "icon.ico"
    },
    "portable": {
      "artifactName": "KeepCalm.exe",
      "requestExecutionLevel": "user"
    },
    "publish": {
      "provider": "github",
      "owner": "ryhanschutz",
      "repo": "keepcalm-yole"
    }
  },
  "author": "Ryhan Schutz",
  "license": "MIT",
  "devDependencies": {
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
